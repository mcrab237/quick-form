rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Auth check
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: Check if user is admin
    function isAdmin() {
      return isAuthenticated() 
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // -----------------------------------------------------------------------
    // BUSINESS SUBMISSIONS COLLECTION - Secure Business Form Data
    // -----------------------------------------------------------------------
    // Stores business information submitted through the public form
    // - Anyone can CREATE (submit the form)
    // - Only authenticated admins can READ
    // - Only authenticated admins can UPDATE (mark as reviewed, etc.)
    // - Only authenticated admins can DELETE
    match /businessSubmissions/{submissionId} {
      // Only admins can read submissions
      allow read: if isAuthenticated();
      
      // Anyone can create a submission (public form)
      // Validate required fields are present
      allow create: if request.resource.data.keys().hasAll([
        'businessType',
        'legalBusinessName',
        'ein',
        'address',
        'city',
        'state',
        'zip',
        'firstName',
        'lastName',
        'dateOfBirth',
        'routingNumber',
        'accountNumber',
        'status',
        'reviewed'
      ])
      && request.resource.data.status == 'pending'
      && request.resource.data.reviewed == false;
      
      // Only authenticated users can update (for marking as reviewed)
      allow update: if isAuthenticated();
      
      // Only authenticated users can delete
      allow delete: if isAuthenticated();
    }
  }
}
