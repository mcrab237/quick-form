rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Auth check
    function isAuthenticated() {
      return request.auth != null;
    }

    // -----------------------------------------------------------------------
    // BUSINESS SUBMISSIONS COLLECTION - Secure Business Form Data
    // -----------------------------------------------------------------------
    match /businessSubmissions/{submissionId} {
      allow read: if isAuthenticated();
      
      allow create: if request.resource.data.keys().hasAll([
        'businessType',
        'legalBusinessName',
        'ein',
        'address',
        'city',
        'state',
        'zip',
        'firstName',
        'lastName',
        'dateOfBirth',
        'routingNumber',
        'accountNumber',
        'status',
        'reviewed'
      ])
      && request.resource.data.status == 'pending'
      && request.resource.data.reviewed == false;
      
      // Admins can update. Unauthenticated users can update ONLY when completing
      // SSN via resend link: token must match, not expired, and only ssn/email/ssnTokenUsedAt/__tokenVerify allowed
      allow update: if isAuthenticated()
        || (resource.data.ssnCompletionToken != null
            && resource.data.ssnCompletionToken == request.resource.data.__tokenVerify
            && resource.data.ssnTokenExpiresAt != null
            && resource.data.ssnTokenExpiresAt > request.time
            && !("ssnTokenUsedAt" in resource.data)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ssn', 'email', 'ssnTokenUsedAt', '__tokenVerify']));
      
      allow delete: if isAuthenticated();
    }

    // -----------------------------------------------------------------------
    // SSN COMPLETION LINKS - Public read by token (doc ID = unguessable token)
    // -----------------------------------------------------------------------
    // Created by admin when "Resend for SSN" is clicked.
    // Anyone with the token can read (to load the completion page).
    // Modify as needed for production (e.g., add backend to validate token).
    match /ssnCompletionLinks/{token} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
  }
}
